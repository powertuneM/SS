<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Car Detailing</title>
  <style>
    body { margin:0; font-family:sans-serif; background:#0a0a0a; color:#fff; }
    header { position:fixed; width:100%; top:0; background:rgba(0,0,0,0.7); display:flex; justify-content:space-around; padding:10px 0; z-index:10; }
    header a { color:#fff; text-decoration:none; font-size:14px; }
    section { padding:80px 20px; }
    .hero { height:100vh; background:url('https://source.unsplash.com/800x1200/?car,detailing,polish') center/cover; display:flex; align-items:center; justify-content:center; text-align:center; }
    .hero h1 { font-size:32px; }
    .grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .grid img { width:100%; border-radius:10px; cursor:pointer; }

    .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); justify-content:center; align-items:center; z-index:100; }
    .modal img { max-width:90%; max-height:90%; }

    .compare { position:relative; width:100%; overflow:hidden; border-radius:10px; }
    .compare img { width:100%; display:block; }
    .compare .after { position:absolute; top:0; left:0; width:50%; overflow:hidden; }
    .slider { position:absolute; top:0; left:50%; width:3px; height:100%; background:#fff; }

    form { display:flex; flex-direction:column; gap:10px; }
    input, textarea { padding:10px; border:none; border-radius:5px; }
    button { padding:10px; background:#fff; color:#000; border:none; }

    .fixed-bar { position:fixed; bottom:0; left:0; width:100%; display:flex; z-index:200; }
    .fixed-bar a { flex:1; text-align:center; padding:15px 0; text-decoration:none; font-weight:bold; }
    .tel { background:#fff; color:#000; }
    .mail { background:#333; color:#fff; }

    @media(max-width:600px){ .grid { grid-template-columns:1fr; } }
  </style>
</head>
<body>

<header>
  <a href="#top">TOP</a>
  <a href="#about">ABOUT</a>
  <a href="#works">WORKS</a>
  <a href="#contact">CONTACT</a>
</header>

<section id="top" class="hero">
  <div>
    <h1>CAR DETAILING</h1>
    <p>洗練された美しさをあなたの愛車に</p>
  </div>
</section>

<section id="about">
  <h2>ABOUT</h2>
  <p>カーディテーリング・コーティング専門。車・バイクどちらも対応。</p>
</section>

<section id="works">
  <h2>WORKS</h2>

  <div class="grid">
    <img src="https://source.unsplash.com/400x400/?car,detailing,black" alt="セダン施工">
    <img src="https://source.unsplash.com/400x400/?car,polishing" alt="研磨作業">
    <img src="https://source.unsplash.com/400x400/?car,coating,gloss" alt="コーティング">
    <img src="https://source.unsplash.com/400x400/?motorcycle,detailing" alt="バイク施工">
    <img src="https://source.unsplash.com/400x400/?scooter,cleaning" alt="スクーター施工">
  </div>

  <h3>ヘッドライト Before / After</h3>

  <div class="compare" id="compareBox">
    <img src="https://source.unsplash.com/800x400/?dirty,headlight,car">
    <div class="after">
      <img src="https://source.unsplash.com/800x400/?clean,headlight,car">
    </div>
    <div class="slider" id="slider"></div>
  </div>

</section>

<section id="contact">
  <h2>CONTACT</h2>
  <p>TEL: XXX-XXXX-XXXX</p>
  <form>
    <input type="text" placeholder="お名前">
    <input type="email" placeholder="メール">
    <textarea placeholder="お問い合わせ内容"></textarea>
    <button type="submit">送信</button>
  </form>
</section>

<div class="modal" id="modal">
  <img id="modalImg">
</div>

<div class="fixed-bar">
  <a href="tel:0000000000" class="tel">電話する</a>
  <a href="mailto:example@email.com" class="mail">メールする</a>
</div>

<script>
const images = document.querySelectorAll('.grid img');
const modal = document.getElementById('modal');
const modalImg = document.getElementById('modalImg');

images.forEach(img => {
  img.addEventListener('click', () => {
    modal.style.display = 'flex';
    modalImg.src = img.src;
  });
});

modal.addEventListener('click', () => {
  modal.style.display = 'none';
});

const compareBox = document.getElementById('compareBox');
const after = compareBox.querySelector('.after');
const slider = document.getElementById('slider');

compareBox.addEventListener('mousemove', (e) => {
  const rect = compareBox.getBoundingClientRect();
  let x = e.clientX - rect.left;
  if(x < 0) x = 0;
  if(x > rect.width) x = rect.width;
  after.style.width = x + 'px';
  slider.style.left = x + 'px';
});

compareBox.addEventListener('touchmove', (e) => {
  const rect = compareBox.getBoundingClientRect();
  let x = e.touches[0].clientX - rect.left;
  if(x < 0) x = 0;
  if(x > rect.width) x = rect.width;
  after.style.width = x + 'px';
  slider.style.left = x + 'px';
});
</script>

</body>
</html>
